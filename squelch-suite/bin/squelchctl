#!/usr/bin/env bash
# squelchctl — Control your Squelch Radio instance via mpv IPC

SOCKET="/tmp/mpvsocket"
CONFIG="$HOME/.config/squelch/stations"

# 💬 Send a command to mpv
send() {
  echo "$1" | socat - "$SOCKET"
}

# ⏸ Pause or play
pause_station() {
  send '{ "command": ["cycle", "pause"] }'
}

# ⏹ Stop (quit mpv)
stop_station() {
  send '{ "command": ["quit"] }'
}

# 🧾 Print now playing info
station_status() {
  local metadata icy
  metadata=$(echo '{ "command": ["get_property", "metadata"] }' | socat - "$SOCKET")
  icy=$(echo "$metadata" | jq -r '.data["icy-title"] // empty')
  if [[ -n "$icy" ]]; then
    echo "🎶 Now Playing: $icy"
  else
    echo "⚠️  No metadata available."
  fi
}

# 🔁 Load station by name or URL
load_station() {
  local input="$1"
  local url=""

  # If name matches a station in config
  if [[ -f "$CONFIG" ]]; then
    url=$(grep "^$input=" "$CONFIG" | cut -d= -f2- || true)
  fi

  # If no match, assume raw URL
  [[ -z "$url" ]] && url="$input"

  if [[ -z "$url" ]]; then
    echo "❌ Could not resolve station or URL: $input"
    return 1
  fi

  echo "🎶 Loading: $url"
  send '{ "command": ["loadfile", "'"$url"'", "replace"] }'
}

# 🧭 Route commands
case "${1:-}" in
  pause) pause_station ;;
  stop) stop_station ;;
  status) station_status ;;
  load) shift; load_station "$1" ;;
  *) echo "Usage: squelchctl [pause|stop|status|load <name|url>]" ;;
esac
